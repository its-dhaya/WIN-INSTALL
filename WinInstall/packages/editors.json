  "vscode": {
    "aliases": ["code", "visual-studio-code"],
    "winget_id": "Microsoft.VisualStudioCode",
    "display_name": "Visual Studio Code",
    "description": "VS Code editor by Microsoft",
    "install_dir_hints": [
      "%LOCALAPPDATA%\\Programs\\Microsoft VS Code"
    ],
    "path_additions": [
      "%LOCALAPPDATA%\\Programs\\Microsoft VS Code\\bin"
    ],
    "env_vars": {},
    "verify_cmd": "code --version",
    "post_install_msg": "VS Code installed! Use 'code .' to open any folder from the terminal."
  },

