  "7zip": {
    "aliases": ["7z", "sevenzip"],
    "winget_id": "7zip.7zip",
    "display_name": "7-Zip",
    "description": "7-Zip file archiver",
    "install_dir_hints": [
      "C:\\Program Files\\7-Zip"
    ],
    "path_additions": [
      "C:\\Program Files\\7-Zip"
    ],
    "env_vars": {},
    "verify_cmd": "7z i",
    "post_install_msg": "7-Zip installed! Use '7z' from any terminal."
  }
